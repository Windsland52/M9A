{
    "task": [
        {
            "name": "切换账号",
            "entry": "SwitchAccount",
            "option": [
                "目标账号(可选)"
            ],
            "resource": ["官服"],
            "group": ["daily"],
            "description": "<span style=\"color:tomato;font-size:15px\">留空时会下滑到账号列表底部并切换至最后一个账号；填写目标账号时会按输入内容查找并在账号列表中继续下滑</span><br><span style=\"color:tomato;font-size:15px\">切换后可继续添加任务，以便多账号多配置运行任务</span><br><span style=\"color:tomato;font-size:15px\">目前该功能仅支持官服，且建议使用该功能的用户将模拟器分辨率调至1280*720</span>"
        }
    ],
    "option": {
        "目标账号(可选)": {
            "type": "input",
            "label": "目标账号",
            "inputs": [
                {
                    "name": "账号",
                    "label": "账号",
                    "pipeline_type": "string",
                    "default": "",
                    "description": "留空则下滑到账号列表底部后切换最后一个账号"
                }
            ],
            "pipeline_override": {
                "SwitchAccountSelect": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "account": "{账号}"
                            }
                        }
                    }
                }
            }
        }
    }
}
